APP_NAME=Tupã
ENVIRONMENT=production

# URL fornecida pelo PostgreSQL em nuvem (Neon, Supabase, RDS, Railway etc.).
# URLs postgresql:// e postgres:// sao convertidas automaticamente para asyncpg.
# Parametros sslmode=require tambem sao normalizados.
DATABASE_URL=CHANGE_ME_CLOUD_POSTGRESQL_URL

# Generate with: ./publish.sh init
SERVICE_TOKEN=CHANGE_ME
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME
JWT_PRIVATE_KEY=CHANGE_ME
JWT_PUBLIC_KEY=CHANGE_ME
JWT_KEY_ID=tupa-production-1
JWT_ISSUER=tupa

ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7
LOGIN_RATE_LIMIT=10
LOGIN_RATE_WINDOW_SECONDS=60

# Host port exposed by Docker Compose.
TUPA_PORT=8000
